---
import { COLLAPSE_THRESHOLD } from "../../constants/constants";
import { getSortedPosts } from "../../utils/content-utils";
import { getPostUrlBySlug } from "../../utils/url-utils";
import WidgetLayout from "./WidgetLayout.astro";

interface Props {
	series: string;
	class?: string;
	style?: string;
}

const { series } = Astro.props;
const className = Astro.props.class;
const style = Astro.props.style;

// getSortedPosts 已按发布时间倒序（pinned 优先），此处无需再排序
const allPosts = await getSortedPosts();
const seriesPosts = allPosts.filter((post) => post.data.series === series);

const COLLAPSED_HEIGHT = "15rem";
const isCollapsed = seriesPosts.length > COLLAPSE_THRESHOLD;
---

<WidgetLayout
	name={`专栏：${series}`}
	id="series-posts"
	isCollapsed={isCollapsed}
	collapsedHeight={COLLAPSED_HEIGHT}
	class={className}
	style={style}
>
	<div class="flex flex-col gap-1">
		{seriesPosts.map((post) => (
			<a
				href={getPostUrlBySlug(post.id)}
				class="block p-2 rounded-sm hover:bg-(--btn-plain-bg-hover) truncate transition"
			>
				<div class="text-sm font-medium text-neutral-800 dark:text-neutral-200 truncate">
					{post.data.title}
				</div>
				<div class="text-xs text-neutral-500 dark:text-neutral-400">
					{post.data.published.toLocaleDateString("zh-CN")}
				</div>
			</a>
		))}
	</div>
</WidgetLayout>
