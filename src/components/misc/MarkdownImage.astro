---
import { Image } from "astro:assets";
import path from "node:path";

interface Props {
	src: string;
	alt: string;
}

const { src, alt } = Astro.props;
const isRemote = src.startsWith("http");

// 与 ImageWrapper 保持一致：通过 import.meta.glob 让 Vite 静态分析本地资源
let img: ImageMetadata | undefined;
if (!isRemote) {
	const files = import.meta.glob<ImageMetadata>(
		"../../**/*.{png,jpg,jpeg,webp,gif,avif,svg}",
		{ import: "default" },
	);
	const normalizedPath = path
		.normalize(path.join("../../", src))
		.replace(/\\/g, "/");
	const file = files[normalizedPath];
	if (!file) {
		console.error(
			`\n[ERROR] Image file not found: ${normalizedPath.replace("../../", "src/")}`,
		);
	} else {
		img = await file();
	}
}
---

<figure class="flex flex-col items-center">
	{
		isRemote ? (
			<img src={src} alt={alt} class="rounded-lg" loading="lazy" />
		) : img ? (
			<Image
				src={img}
				alt={alt}
				class="rounded-lg"
				widths={[400, 800, 1200]}
				sizes="(max-width: 800px) 100vw, 800px"
				format="webp"
			/>
		) : null
	}
	{alt && <figcaption class="mt-2 text-center text-sm">{alt}</figcaption>}
</figure>
