---
import "@fancyapps/ui/dist/fancybox/fancybox.css";
---

<script>
import { Fancybox } from "@fancyapps/ui";

const GALLERY_SELECTOR = ".custom-md img, #post-cover img";

// Fancybox.bind 是 document.body 级委托，绑一次即永久生效；
// swup 只替换内容容器，委托不受影响，因此无需在每次切页重绑。
let bound = false;

function decorate() {
	for (const img of document.querySelectorAll<HTMLImageElement>(
		GALLERY_SELECTOR,
	)) {
		if (img.hasAttribute("data-fancybox")) continue;
		img.setAttribute("data-fancybox", "gallery");
		if (img.alt) img.setAttribute("data-caption", img.alt);
	}

	if (!bound) {
		Fancybox.bind(GALLERY_SELECTOR, {
			dragToClose: false,
			Toolbar: {
				display: {
					left: ["infobar"],
					middle: [],
					right: ["close"],
				},
			},
			closeButton: false,
			click: false,
			dblclick: false,
			wheel: "slide",
			// biome-ignore lint/suspicious/noExplicitAny: @fancyapps/ui does not export OptionsType
		} as any);
		bound = true;
	}
}

function bindSwupHooks() {
	if (!window.swup) return false;
	window.swup.hooks.on("page:view", decorate);
	window.swup.hooks.on("visit:start", () => Fancybox.close());
	return true;
}

if (!bindSwupHooks()) {
	document.addEventListener("swup:enable", bindSwupHooks, { once: true });
}

// 首屏独立触发：swup 的初始 page:view 可能在本脚本之前已派发。
if (document.readyState === "loading") {
	document.addEventListener("DOMContentLoaded", decorate, { once: true });
} else {
	decorate();
}
</script>
