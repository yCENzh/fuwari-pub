---
import "@fancyapps/ui/dist/fancybox/fancybox.css";
---

<script>
import { Fancybox } from "@fancyapps/ui";

const GALLERY_SELECTOR = ".custom-md img, #post-cover img";

const fancyboxOptions = {
	dragToClose: false,
	Toolbar: {
		display: {
			left: ["infobar"],
			middle: [],
			right: ["close"],
		},
	},
	closeButton: false,
	click: false,
	dblclick: false,
	wheel: "slide",
};

function createFancybox() {
	const images = document.querySelectorAll<HTMLImageElement>(GALLERY_SELECTOR);
	if (images.length === 0) return;

	for (const imageElement of images) {
		if (imageElement.hasAttribute("data-fancybox")) continue;
		imageElement.setAttribute("data-fancybox", "gallery");
		if (imageElement.alt && !imageElement.hasAttribute("data-caption")) {
			imageElement.setAttribute("data-caption", imageElement.alt);
		}
	}

	// biome-ignore lint/suspicious/noExplicitAny: @fancyapps/ui does not export OptionsType
	Fancybox.bind(GALLERY_SELECTOR, fancyboxOptions as any);
}

function destroyFancybox() {
	Fancybox.unbind(GALLERY_SELECTOR);
	Fancybox.close();
}

// swup 是本项目的主切页系统，使用其 hooks 统一处理。
// 如果 swup 尚未就绪，回退到一次性的 DOMContentLoaded 初始化。
function bindSwupHooks() {
	const swup = (window as unknown as { swup?: { hooks: {
		on: (event: string, cb: () => void) => void;
	} } }).swup;
	if (!swup) return false;
	swup.hooks.on("page:view", createFancybox);
	swup.hooks.on("visit:start", destroyFancybox);
	return true;
}

if (!bindSwupHooks()) {
	document.addEventListener("swup:enable", bindSwupHooks, { once: true });
	if (document.readyState === "loading") {
		document.addEventListener("DOMContentLoaded", createFancybox, {
			once: true,
		});
	} else {
		createFancybox();
	}
}
</script>
